{
  "appId": "com.sjeary.sharegpt.desktop.sender",
  "productName": "ShareGPT Sender",
  "asar": true,
  "files": [
    "src/**/*",
    "!src/renderer-next/node_modules/**",
    "!src/renderer-next/src/**",
    "!src/renderer-next/public/**",
    "!src/renderer-next/.gitignore",
    "!src/renderer-next/README.md",
    "!src/renderer-next/eslint.config.js",
    "!src/renderer-next/tsconfig*.json",
    "!src/renderer-next/vite.config.ts",
    "!src/renderer-next/components.json",
    "!src/renderer-next/package*.json",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "build/bin",
      "to": "bin",
      "filter": [
        "**/*"
      ]
    }
  ],
  "directories": {
    "output": "release_sender"
  },
  "win": {
    "target": [
      "nsis"
    ],
    "artifactName": "sharegpt-sender-${version}.${ext}",
    "executableName": "sharegpt_sender",
    "signAndEditExecutable": false
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "ShareGPT Sender"
  },
  "mac": {
    "target": [
      "zip",
      "dmg"
    ],
    "artifactName": "sharegpt-sender-${version}-${arch}.${ext}"
  },
  "extraMetadata": {
    "main": "src/main/main_sender.js",
    "name": "sharegpt-sender-desktop"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "Sjeary",
      "repo": "ShareGPT"
    }
  ]
}

