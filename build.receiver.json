{
  "appId": "com.sjeary.sharegpt.desktop.receiver",
  "productName": "ShareGPT Receiver",
  "asar": true,
  "files": ["src/**/*", "package.json"],
  "extraResources": [
    {
      "from": "build/bin",
      "to": "bin",
      "filter": ["**/*"]
    }
  ],
  "directories": {
    "output": "release_receiver"
  },
  "win": {
    "target": ["portable"],
    "artifactName": "sharegpt-receiver-${version}.${ext}",
    "executableName": "sharegpt_receiver",
    "signAndEditExecutable": false
  },
  "extraMetadata": {
    "main": "src/main/main_receiver.js",
    "name": "sharegpt-receiver-desktop"
  }
}
