[Unit]
Description=ChatPortal X1 V4 Collaboration Server
After=network.target

[Service]
Type=simple
User=chatportal
Group=chatportal
WorkingDirectory=/opt/chatportal-x1-v4-collab
Environment=NODE_ENV=production
Environment=PORT=8088
Environment=HOST=0.0.0.0
Environment=USERS_FILE=/opt/chatportal-x1-v4-collab/data/users.json
Environment=SESSION_TTL_MS=86400000
Environment=HISTORY_MAX=200
ExecStart=/usr/bin/env node server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

